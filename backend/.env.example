# Database (VPS PostgreSQL)
DB_HOST=your_vps_ip
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DATABASE_URL=postgresql://username:password@your_vps_ip:5432/database_name

# JWT
JWT_SECRET=your_jwt_secret_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Session
SESSION_SECRET=your_session_secret

# Email Service - DreamHost SMTP
SMTP_HOST=smtp.dreamhost.com
SMTP_PORT=465
SMTP_SECURE=true

# Email Accounts
EMAIL_NOREPLY=noreply@fluidjobs.ai
EMAIL_NOREPLY_PASS=your_password_here

EMAIL_ASSESSMENTS=assessments@fluidjobs.ai
EMAIL_ASSESSMENTS_PASS=your_password_here

EMAIL_JOBS=jobs@fluidjobs.ai
EMAIL_JOBS_PASS=your_password_here

EMAIL_RECRUITMENT=recruitment@fluidjobs.ai
EMAIL_RECRUITMENT_PASS=your_password_here

# MinIO Storage (VPS)
MINIO_ENDPOINT=your_vps_ip
MINIO_PORT=9100
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=your_bucket_name
MINIO_USE_SSL=true

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000